# LLM Configuration (LeLM on Modal)
LLM_PROVIDER=openai_compat
LLM_MODEL=lelm
# Existing LeLM Modal deployment (app name: lelm)
OPENAI_COMPAT_BASE_URL=https://kenwuqianghao--lelm-lelm-chat.modal.run/v1
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=lelm
BOT_SIMPLE_ANALYSIS=true

# Fallback providers (optional)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Database
DATABASE_URL=sqlite+aiosqlite:///./legm.db

# Twitter/X
TWITTER_BEARER_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BOT_USER_ID=

# Bot Configuration
BOT_MENTION_POLL_INTERVAL=60      # seconds
BOT_SEARCH_POLL_INTERVAL=300      # seconds
BOT_MAX_DAILY_PROACTIVE=20
BOT_MONTHLY_BUDGET=450
BOT_DRY_RUN=false
